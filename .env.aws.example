######################################
# AWS
######################################
# AWS environment name (e.g. dev, stg, prd). Used when submitting AWS Batch jobs.
AWS_ENV=dev
# S3 bucket used for job input and output.
BUCKET_NAME=bucket-name

######################################
# Dataset Subset (Works)
######################################
# Enable subset creation to filter works by specific institutions or a list of DOIs.
DATASET_SUBSET_ENABLE=false
# S3 path (excluding bucket name) to a JSON file containing ROR IDs and institution names.
# Works authored by researchers from these institutions will be included.
DATASET_SUBSET_INSTITUTIONS_S3_PATH=meta/institutions.json
# S3 path (excluding bucket name) to a JSON file containing specific Work DOIs to include.
DATASET_SUBSET_DOIS_S3_PATH=meta/work_dois.json

######################################
# Dataset Subset (DMPs)
######################################
# Enable subset creation to filter DMPs by specific institutions or a list of DOIs.
DMP_SUBSET_ENABLE=false
# S3 path (excluding bucket name) to a JSON file containing ROR IDs and institution names.
# DMPs created by researchers from these institutions will be included.
DMP_SUBSET_INSTITUTIONS_S3_PATH=meta/dmp_institutions.json
# S3 path (excluding bucket name) to a JSON file containing specific DMP DOIs to include.
DMP_SUBSET_DOIS_S3_PATH=meta/dmp_dois.json

######################################
# Run Identifiers
######################################
# Each value is typically a date (YYYY-MM-DD) matching the dataset release.
RUN_ID_OPENALEX_WORKS=YYYY-MM-DD
RUN_ID_DATACITE=YYYY-MM-DD
RUN_ID_CROSSREF_METADATA=YYYY-MM-DD
RUN_ID_ROR=YYYY-MM-DD
RUN_ID_DATA_CITATION_CORPUS=YYYY-MM-DD
RUN_ID_SQLMESH_PREV=YYYYMMDDTHHmmssZ
RUN_ID_SQLMESH=YYYYMMDDTHHmmssZ
RUN_ID_SYNC_WORKS=YYYYMMDDTHHmmssZ
RUN_ID_SYNC_DMPS=YYYYMMDDTHHmmssZ
RUN_ID_ENRICH_DMPS=YYYYMMDDTHHmmssZ
RUN_ID_DMP_WORKS_SEARCH=YYYYMMDDTHHmmssZ
RUN_ID_MERGE_RELATED_WORKS=YYYYMMDDTHHmmssZ

######################################
# ROR
######################################
# URL to download the ROR dataset from Zenodo.
ROR_DOWNLOAD_URL=https://zenodo.org/records/18761279/files/v2.3-2026-02-24-ror-data.zip
# Expected MD5 checksum of the ROR archive.
ROR_HASH=md5:940ae94e1de84e7e1d805db961389629

######################################
# Crossref Metadata
######################################
# S3 bucket containing Crossref Metadata snapshots.
CROSSREF_METADATA_BUCKET_NAME=api-snapshots-reqpays-crossref
# Name of the Crossref metadata archive to download.
CROSSREF_METADATA_FILE_NAME=April_2025_Public_Data_File_from_Crossref.tar

######################################
# Crossref Metadata Transform
######################################
CROSSREF_METADATA_TRANSFORM_BATCH_SIZE=500
CROSSREF_METADATA_TRANSFORM_ROW_GROUP_SIZE=500000
CROSSREF_METADATA_TRANSFORM_ROW_GROUPS_PER_FILE=4
CROSSREF_METADATA_TRANSFORM_MAX_WORKERS=32

######################################
# DataCite
######################################
# S3 bucket containing DataCite monthly data files.
DATACITE_BUCKET_NAME=monthly-datafile.datacite.org

######################################
# DataCite Transform
######################################
DATACITE_TRANSFORM_BATCH_SIZE=150
DATACITE_TRANSFORM_ROW_GROUP_SIZE=250000
DATACITE_TRANSFORM_ROW_GROUPS_PER_FILE=8
DATACITE_TRANSFORM_MAX_WORKERS=8

######################################
# OpenAlex Works
######################################
# S3 bucket containing OpenAlex data.
OPENALEX_BUCKET_NAME=openalex

######################################
# OpenAlex Works Transform
######################################
OPENALEX_WORKS_TRANSFORM_BATCH_SIZE=16
OPENALEX_WORKS_TRANSFORM_ROW_GROUP_SIZE=200000
OPENALEX_WORKS_TRANSFORM_ROW_GROUPS_PER_FILE=4
OPENALEX_WORKS_TRANSFORM_MAX_WORKERS=32
OPENALEX_WORKS_TRANSFORM_INCLUDE_XPAC=false

######################################
# DMP Works Search
######################################
DMP_WORKS_SEARCH_QUERY_BUILDER=build_dmp_works_search_baseline_query
# DMP_WORKS_SEARCH_RERANK_MODEL=model_name
DMP_WORKS_SEARCH_SCROLL_TIME=360m
DMP_WORKS_SEARCH_BATCH_SIZE=250
DMP_WORKS_SEARCH_MAX_RESULTS=100
DMP_WORKS_SEARCH_PROJECT_END_BUFFER_YEARS=3
DMP_WORKS_SEARCH_PARALLEL_SEARCH=false
DMP_WORKS_SEARCH_INCLUDE_NAMED_QUERIES_SCORE=true
DMP_WORKS_SEARCH_MAX_CONCURRENT_SEARCHES=125
DMP_WORKS_SEARCH_MAX_CONCURRENT_SHARD_REQUESTS=12
DMP_WORKS_SEARCH_INNER_HITS_SIZE=50
DMP_WORKS_SEARCH_ROW_GROUP_SIZE=50000
DMP_WORKS_SEARCH_ROW_GROUPS_PER_FILE=4
# DMP_WORKS_SEARCH_DMPS_START_DATE=YYYY-MM-DD
# DMP_WORKS_SEARCH_DMPS_END_DATE=YYYY-MM-DD

######################################
# OpenSearch Client
######################################
OPENSEARCH_HOST=opensearch-domain.region.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_AUTH_TYPE=aws
OPENSEARCH_REGION=aws-region
OPENSEARCH_SERVICE=es
OPENSEARCH_POOL_MAXSIZE=20
OPENSEARCH_TIMEOUT=300

######################################
# OpenSearch Sync
######################################
OPENSEARCH_SYNC_MAX_PROCESSES=8
OPENSEARCH_SYNC_CHUNK_SIZE=1000
OPENSEARCH_SYNC_MAX_CHUNK_BYTES=104857600
OPENSEARCH_SYNC_MAX_RETRIES=10
OPENSEARCH_SYNC_INITIAL_BACKOFF=2
OPENSEARCH_SYNC_MAX_BACKOFF=600
OPENSEARCH_SYNC_DRY_RUN=false
OPENSEARCH_SYNC_MEASURE_CHUNK_SIZE=false
OPENSEARCH_SYNC_MAX_ERROR_SAMPLES=50
OPENSEARCH_SYNC_STAGGERED_START=false

######################################
# SQLMesh
######################################
# Paths (DUCKDB_DATABASE, CROSSREF_METADATA_PATH, DATACITE_PATH,
# OPENALEX_WORKS_PATH, OPENSEARCH_PATH, ROR_PATH, DATA_CITATION_CORPUS_PATH,
# DOI_STATE_EXPORT_PATH, WORKS_INDEX_EXPORT_PATH) are set automatically
# by AWS Batch job definitions.

# DuckDB
DUCKDB_THREADS=32
DUCKDB_MEMORY_LIMIT=225GB

# Audits
AUDIT_CROSSREF_METADATA_WORKS_THRESHOLD=167008747
AUDIT_DATACITE_WORKS_THRESHOLD=72019576
AUDIT_NESTED_OBJECT_LIMIT=20000
AUDIT_OPENALEX_WORKS_THRESHOLD=264675126

# Maximum number of states to keep for each DOI in the DOI state export
MAX_DOI_STATES=3
# Maximum number of relation degrees
MAX_RELATION_DEGREES=100

# Crossref Threads
CROSSREF_CROSSREF_METADATA_THREADS=32
CROSSREF_INDEX_WORKS_METADATA_THREADS=32

# Data Citation Corpus Threads
DATA_CITATION_CORPUS_THREADS=32

# DataCite Threads
DATACITE_DATACITE_THREADS=32
DATACITE_INDEX_AWARDS_THREADS=32
DATACITE_INDEX_DATACITE_INDEX_THREADS=32
DATACITE_INDEX_FUNDERS_THREADS=32
DATACITE_INDEX_INSTITUTIONS_THREADS=32
DATACITE_INDEX_UPDATED_DATES_THREADS=32
DATACITE_INDEX_WORK_TYPES_THREADS=32
DATACITE_INDEX_WORKS_THREADS=32
DATACITE_INDEX_DATACITE_INDEX_HASHES_THREADS=32

# OpenAlex Threads
OPENALEX_OPENALEX_WORKS_THREADS=32
OPENALEX_INDEX_ABSTRACT_STATS_THREADS=32
OPENALEX_INDEX_ABSTRACTS_THREADS=32
OPENALEX_INDEX_AUTHOR_NAMES_THREADS=32
OPENALEX_INDEX_AWARDS_THREADS=32
OPENALEX_INDEX_FUNDERS_THREADS=32
OPENALEX_INDEX_OPENALEX_INDEX_THREADS=32
OPENALEX_INDEX_PUBLICATION_DATES_THREADS=32
OPENALEX_INDEX_TITLE_STATS_THREADS=32
OPENALEX_INDEX_TITLES_THREADS=32
OPENALEX_INDEX_UPDATED_DATES_THREADS=32
OPENALEX_INDEX_WORKS_METADATA_THREADS=32
OPENALEX_INDEX_OPENALEX_INDEX_HASHES_THREADS=32

# OpenSearch Threads
OPENSEARCH_CURRENT_DOI_STATE_THREADS=32
OPENSEARCH_EXPORT_THREADS=32
OPENSEARCH_NEXT_DOI_STATE_THREADS=32

# Relations Threads
RELATIONS_CROSSREF_METADATA_DEGREES_THREADS=32
RELATIONS_CROSSREF_METADATA_THREADS=32
RELATIONS_DATA_CITATION_CORPUS_THREADS=32
RELATIONS_DATACITE_DEGREES_THREADS=16
RELATIONS_DATACITE_THREADS=16
RELATIONS_RELATIONS_INDEX_THREADS=32

# ROR Threads
ROR_ROR_THREADS=32
ROR_INDEX_THREADS=32

# Works Index Threads
WORKS_INDEX_EXPORT_THREADS=32